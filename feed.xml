---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://w3.org">
  <channel>
    <title>Shine Injung Park</title>
    <description>PortFolio &amp; Blog</description>
    <link>https://letyoushine.github.io/</link>
    <atom:link href="https://letyoushine.github.io/feed.xml" rel="self" type="application/rss+xml"/>
    <pubDate>{{ site.time | date_to_rfc822 }}</pubDate>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    <generator>Jekyll v{{ jekyll.version }}</generator>
    {% for post in site.posts limit:10 %}
      <item>
        <title>{{ post.title | xml_escape }}</title>
        <description>{{ post.content | xml_escape }}</description>
        <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
        <link>https://letyoushine.github.io{{ post.url }}</link>
        <guid isPermaLink="true">https://letyoushine.github.io{{ post.url }}</guid>
      </item>
    {% endfor %}
  </channel>
</rss>
